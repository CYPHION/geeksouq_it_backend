NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DB_NAME=
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_DIALECT=postgres

# Outlook / Microsoft 365 SMTP (used by utils/email.js)
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=

# Gmail app password (used by utils/emailService.js for brief-form emails)
EMAIL_SEND=
EMAIL_SEND_PASSWORD=

# Base URL used in email links
URL_EMAIL=https://api.geeksouq.com
